#!/usr/bin/env ruby

DEST = '~/code/dot.files'

# Detect OS
os = `uname`.strip
os_dir = os == 'Darwin' ? 'osx' : 'linux'

# common: OS-independent files
`mkdir -p #{DEST}/common/bin`
`mkdir -p #{DEST}/common/UltiSnips`
`mkdir -p #{DEST}/common/nvim/lua`
`mkdir -p #{DEST}/common/nvim/luasnippets`

`cp ~/.config/nvim/init.lua #{DEST}/common/nvim/init.lua`
`cp -r ~/.config/nvim/lua/* #{DEST}/common/nvim/lua`
`cp -r ~/.config/nvim/luasnippets/* #{DEST}/common/nvim/luasnippets`
`cp ~/.ghci #{DEST}/common/dot.ghci`
`cp ~/.gitconfig #{DEST}/common/dot.gitconfig`
`cp ~/.config/tmux/tmux.conf #{DEST}/common/dot.tmux.conf`
`cp -r ~/bin/* #{DEST}/common/bin`
`cp -r ~/.config/nvim/UltiSnips/* #{DEST}/common/UltiSnips`

# OS-specific files
`mkdir -p #{DEST}/#{os_dir}/oh-my-zsh-themes`

`cp ~/.zshrc #{DEST}/#{os_dir}/dot.zshrc`
`cp ~/.oh-my-zsh/lib/aliases.zsh #{DEST}/#{os_dir}/oh-my-zsh-lib-aliases.zsh`
`cp -r ~/.oh-my-zsh/themes/fino* #{DEST}/#{os_dir}/oh-my-zsh-themes`
